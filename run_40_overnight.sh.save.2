#!/bin/bash

# 연구자님이 지정하신 파이썬 코드 파일명
SCRIPT="srrhuif_nd_vs_adam_debug_Qlandscape.py"

# 20가지 황금비율 & 한계 테스트 파라미터 셋 (r_std, P_max, Alpha)
PARAMS=(
    "1.5 0.014 0.99"
    "1.5 0.018 0.99"
    "1.8 0.013 0.99"
    "1.8 0.025 0.80"
    "1.8 0.025 0.99"
    "2.0 0.020 0.80"
    "2.0 0.020 0.99"
    "2.5 0.031 0.65"
    "2.5 0.038 0.80"
    "3.0 0.050 0.55"
    "3.0 0.050 0.70"
    "3.0 0.060 0.65"
    "3.5 0.061 0.48"
    "3.5 0.061 0.63"
    "4.0 0.080 0.42"
    "4.0 0.080 0.55"
    "4.5 0.101 0.36"
    "4.5 0.101 0.48"
    "5.0 0.125 0.33"
    "5.0 0.125 0.45"
)

# Beta 2.0 (일반)과 3.0 (강한 에어백) 교차 테스트
BETAS=(2.0 3.0)

echo "========================================================="
echo "🚀 40-Combo Q-Landscape Overnight Experiments Started..."
echo "========================================================="

count=1
total=$(( ${#BETAS[@]} * ${#PARAMS[@]} ))

# 이중 루프: Beta -> 20개 파라미터 조합 순회
for beta in "${BETAS[@]}"; do
    for p_set in "${PARAMS[@]}"; do
        
        # 문자열 파싱
        read -r r_std p_max alpha <<< "$p_set"
        
        echo "---------------------------------------------------------"
        echo "[Run $count/$total] Beta=$beta | R=$r_std | P_max=$p_max | Alpha=$alpha"
        echo "---------------------------------------------------------"
        
        # 파이썬 실행
        python -u $SCRIPT --alpha "$alpha" --beta "$beta" --r_std "$r_std" --p_max "$p_max"
        
        ((count++))	
    done
done

echo "========================================================="
echo "✅ All 40 Experiments Completed!"
echo "Check the 'results_cartpole' directory for the Q-Landscape plots."
echo "========================================================="
